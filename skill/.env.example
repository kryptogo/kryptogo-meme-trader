# KryptoGO Meme Trader - Environment Variables
#
# This file should be placed at: ~/.openclaw/workspace/.env
# Copy and fill in your values:
#   cp .env.example ~/.openclaw/workspace/.env
#
# SECURITY: .env contains secrets. Never commit it.
#   - chmod 600 ~/.openclaw/workspace/.env (setup.py does this automatically)

# Required: Your KryptoGO API key
# Get one at: https://www.kryptogo.xyz/account
KRYPTOGO_API_KEY=sk_live_your_key_here

# Required: Agent's Solana wallet private key (base58-encoded)
# Generated automatically by: python3 scripts/setup.py
SOLANA_PRIVATE_KEY=

# Required: Agent's Solana wallet public address
# Generated automatically by: python3 scripts/setup.py
SOLANA_WALLET_ADDRESS=
